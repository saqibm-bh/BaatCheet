NODE_ENV=development

PORT=5000

# Frontend URL(s) (comma-separated) for CORS
FRONTEND_URL=

# current server url to serve static files
# keep the url of the current server ip
SERVER_URL=https://baatcheet-backend-dweybkd0esdvazfp.westeurope-01.azurewebsites.net

# database creds
# MONGO_URI="yourDBURL" if you don't prefer the below one
MONGO_URI=mongodb://mongod:27017
DB_NAME=BaatCheet
DB_MIN_POOL_SIZE=2
DB_MAX_POOL_SIZE=5

COOKIE_VALIDITY_SEC=172800 
ACCESS_TOKEN_VALIDITY_SEC=182800 
REFRESH_TOKEN_VALIDITY_SEC=604800 
TOKEN_ISSUER=api.your-app.local
TOKEN_AUDIENCE=your-app.local

JWT_SECRET_KEY=replace_with_your_own_long_random_secret

# Cloudinary media storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=baatcheet

# Optional hardening controls
CLOUDINARY_STARTUP_CHECK=true
CLOUDINARY_MAX_IMAGE_SIZE_MB=10
CLOUDINARY_MAX_VIDEO_SIZE_MB=50
CLOUDINARY_MAX_RAW_SIZE_MB=20

# AI via OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
SUMMARY_MAX_MESSAGES=50
