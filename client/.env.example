# Required: Backend API base URL used by Axios
VITE_API_URL=https://your-backend-domain.com

# Optional: Override Socket.IO endpoint (defaults to VITE_API_URL)
VITE_SOCKET_URL=https://your-backend-domain.com

# Optional: Override WebRTC signaling endpoint (defaults to VITE_SOCKET_URL, then VITE_API_URL)
VITE_SIGNALING_URL=https://your-backend-domain.com

# Optional legacy compatibility keys (only if you still rely on old names)
# VITE_SERVER_URL=https://your-backend-domain.com
# VITE_SOCKET_URI=https://your-backend-domain.com
# VITE_SIGNALLING_SERVER_URL=https://your-backend-domain.com
